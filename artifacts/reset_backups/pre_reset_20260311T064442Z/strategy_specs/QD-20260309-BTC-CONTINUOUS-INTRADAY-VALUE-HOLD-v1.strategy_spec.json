      "Close > EMA_50",
      "Close > VWAP",
      "low >= EMA_21 - 0.30 * ATR_14",
      "RSI_14 >= 51",
      "ADX_14 >= 12",
      "PLUS_DI_14 > MINUS_DI_14"
