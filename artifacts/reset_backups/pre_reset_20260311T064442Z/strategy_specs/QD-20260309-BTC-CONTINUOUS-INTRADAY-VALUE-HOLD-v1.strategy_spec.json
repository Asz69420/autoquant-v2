    "short": [
      "Close < EMA_21",
      "Close < EMA_50",
      "Close < VWAP",
      "high <= EMA_21 + 0.30 * ATR_14",
      "RSI_14 <= 49",
      "ADX_14 >= 12",
      "MINUS_DI_14 > PLUS_DI_14"
    ]
  },
  "exit_rules": {
    "long": ["Stop loss: 0.95 * ATR_14 below entry","Take profit: 2.6 * ATR_14 above entry","Early exit if Close crosses_below EMA_21","Time stop: 10 bars"],
    "short": ["Stop loss: 0.95 * ATR_14 above entry","Take profit: 2.6 * ATR_14 below entry","Early exit if Close crosses_above EMA_21","Time stop: 10 bars"]
  },
  "position_sizing": {"risk_per_trade_pct": 0.004},
  "regime_filter": {"allowed_regimes": ["trending","transitional"],"detection_method": "Continuous intraday value-hold continuation. BTC stays eligible as long as price accepts above or below the fast/medium anchor stack and VWAP, and entries only require shallow resets inside that live state. This is deliberately broad and continuous rather than event-gated."},
