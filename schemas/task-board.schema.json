{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "autoquant://schemas/task-board",
  "title": "Task Board",
  "description": "Deterministic task board for roadmap progress and automation-safe task state.",
  "type": "object",
  "required": ["version", "generated_at", "summary", "tasks"],
  "properties": {
    "version": { "type": "string", "const": "task-board-v1" },
    "generated_at": { "type": "string", "format": "date-time" },
    "summary": {
      "type": "object",
      "required": ["queued", "active", "blocked", "done", "dropped", "total"],
      "properties": {
        "queued": { "type": "integer", "minimum": 0 },
        "active": { "type": "integer", "minimum": 0 },
        "blocked": { "type": "integer", "minimum": 0 },
        "done": { "type": "integer", "minimum": 0 },
        "dropped": { "type": "integer", "minimum": 0 },
        "total": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "type",
          "status",
          "priority",
          "owner",
          "shared",
          "created_at",
          "updated_at"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^TASK-[0-9]{4}$" },
          "title": { "type": "string", "minLength": 1 },
          "type": {
            "type": "string",
            "enum": ["milestone", "feature", "infra", "research", "migration", "maintenance", "governance"]
          },
          "status": {
            "type": "string",
            "enum": ["queued", "active", "blocked", "done", "dropped"]
          },
          "priority": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"]
          },
          "owner": { "type": "string", "minLength": 1 },
          "shared": { "type": "boolean" },
          "depends_on": {
            "type": "array",
            "items": { "type": "string", "pattern": "^TASK-[0-9]{4}$" }
          },
          "acceptance": {
            "type": "array",
            "items": { "type": "string" }
          },
          "evidence": {
            "type": "array",
            "items": { "type": "string" }
          },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          },
          "notes": { "type": ["string", "null"] },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" },
          "completed_at": { "type": ["string", "null"], "format": "date-time" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
