{"$schema":"http://json-schema.org/draft-07/schema#","$id":"autoquant://schemas/outcome-notes","title":"OutcomeNotes","description":"Post-trade analysis capturing expected vs actual outcomes.","type":"object","required":["id","ts_iso","strategy_spec_id","context","expected_outcome","actual_outcome","analysis"],"properties":{"id":{"type":"string","pattern":"^ON-[0-9]{8}-[A-Z0-9]{4}$"},"ts_iso":{"type":"string","format":"date-time"},"strategy_spec_id":{"type":"string"},"backtest_result_id":{"type":["string","null"]},"trade_ids":{"type":"array","items":{"type":"string"}},"context":{"type":"string","enum":["backtest_review","forward_test","live_trade","regime_shift","market_event"]},"expected_outcome":{"type":"string"},"actual_outcome":{"type":"string"},"analysis":{"type":"string"},"market_conditions":{"type":["object","null"]},"feeds_into":{"type":["string","null"]}},"additionalProperties":false}