{"$schema":"http://json-schema.org/draft-07/schema#","$id":"autoquant://schemas/promotion","title":"Promotion","description":"Graduation gate evaluation for promoting a strategy.","type":"object","required":["id","ts_iso","strategy_spec_id","backtest_result_id","gate_type","criteria","passed","decision"],"properties":{"id":{"type":"string","pattern":"^PM-[0-9]{8}-[A-Z0-9]{4}$"},"ts_iso":{"type":"string","format":"date-time"},"strategy_spec_id":{"type":"string"},"backtest_result_id":{"type":"string"},"gate_type":{"type":"string","enum":["backtest_to_forward","forward_to_live"]},"criteria":{"type":"object","required":["min_trades","min_weeks","min_profit_factor","max_drawdown_pct","pf_degradation_max_pct"],"properties":{"min_trades":{"type":"integer"},"min_weeks":{"type":"integer"},"min_profit_factor":{"type":"number"},"max_drawdown_pct":{"type":"number"},"pf_degradation_max_pct":{"type":"number"}}},"evaluation":{"type":"object"},"passed":{"type":"boolean"},"failed_criteria":{"type":"array","items":{"type":"string"}},"decision":{"type":"string","enum":["promoted","rejected","watch","needs_review"]},"notes":{"type":"string"}},"additionalProperties":false}