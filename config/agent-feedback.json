{
  "version": "agent-feedback-v1",
  "description": "Compact agent feedback and Oragorn synthesis loop with low file fragmentation.",
  "cadence": {
    "operational_window_hours": 6,
    "strategic_window_hours": 24
  },
  "sources": {
    "message_board": "data/state/agent_messages.json",
    "quandalf_status": "agents/quandalf/memory/current_cycle_status.json",
    "quandalf_journal": "agents/quandalf/memory/latest_journal.md",
    "frodex_status": "agents/frodex/memory/current_status.md",
    "logron_status": "agents/logron/memory/current_status.md",
    "task_board": "data/state/task_board.json",
    "governance_audit": "data/state/memory_governance_audit.json"
  },
  "routing": {
    "self_heal_if": [
      "known deterministic fix exists",
      "repeated low-risk operational issue"
    ],
    "daily_intel_if": [
      "meaningful strategic change",
      "important recurring weakness",
      "new promotable lesson"
    ],
    "escalate_if": [
      "critical failure",
      "blocked automation",
      "risk to live operation"
    ],
    "oragorn_lane": {
      "suppress_routine_observations": true,
      "board_only_if": [
        "critical failure",
        "blocked automation",
        "decision required",
        "pass or promotion produced",
        "state warning with operational impact"
      ],
      "keep_out_of_oragorn_lane": [
        "repeated high gateway errors without a new failure mode",
        "routine cycle batch summaries with no pass/promotion",
        "repeat integrity-skip/zero-trade observations that are already visible in logs"
      ]
    }
  },
  "output": {
    "summary_path": "data/state/agent_feedback_summary.json"
  }
}
